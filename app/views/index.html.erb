    <!-- Embroidery Styles Section -->
    <div class="mt-16">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Popular Embroidery Stitches</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Chain Stitch -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                    <img src="/images/chain-stitch.svg" 
                         alt="Chain Stitch Example"
                         class="w-full h-64 object-contain bg-white">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">Chain Stitch</h3>
                    <p class="text-gray-600 mb-4">
                        One of the most versatile and widely used embroidery stitches. It creates a chain-like pattern 
                        that can be used for lines, filling, and decorative borders.
                    </p>
                    <p class="text-sm text-gray-500 italic">
                        Simple diagram showing the chain stitch pattern
                    </p>
                </div>
            </div>

            <!-- Satin Stitch -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                    <img src="/images/satin-stitch.svg" 
                         alt="Satin Stitch Example"
                         class="w-full h-64 object-contain bg-white">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">Satin Stitch</h3>
                    <p class="text-gray-600 mb-4">
                        A filling stitch that creates a smooth, lustrous surface. Perfect for creating solid areas of color 
                        and is commonly used in traditional embroidery.
                    </p>
                    <p class="text-sm text-gray-500 italic">
                        Simple diagram showing the satin stitch pattern
                    </p>
                </div>
            </div>

            <!-- French Knot -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                    <img src="/images/french-knot.svg" 
                         alt="French Knot Example"
                         class="w-full h-64 object-contain bg-white">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">French Knot</h3>
                    <p class="text-gray-600 mb-4">
                        A decorative stitch that creates small, dimensional knots. Commonly used for adding texture, 
                        creating flower centers, and adding delicate details.
                    </p>
                    <p class="text-sm text-gray-500 italic">
                        Simple diagram showing the French knot technique
                    </p>
                </div>
            </div>

            <!-- Stem Stitch -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                    <img src="/images/stitches/stem-stitch.svg" 
                         alt="Stem Stitch Example"
                         class="w-full h-64 object-contain bg-white">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">Stem Stitch</h3>
                    <p class="text-gray-600 mb-4">
                        A versatile stitch perfect for creating smooth lines and curves. Commonly used for stems, vines, 
                        and outlining shapes in embroidery designs.
                    </p>
                </div>
            </div>

            <!-- Back Stitch -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                    <img src="/images/stitches/back-stitch.svg" 
                         alt="Back Stitch Example"
                         class="w-full h-64 object-contain bg-white">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">Back Stitch</h3>
                    <p class="text-gray-600 mb-4">
                        A fundamental stitch that creates a solid line. Perfect for outlines, lettering, and creating 
                        fine details in your embroidery work.
                    </p>
                </div>
            </div>

            <!-- Lazy Daisy -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                    <img src="/images/stitches/lazy-daisy.svg" 
                         alt="Lazy Daisy Example"
                         class="w-full h-64 object-contain bg-white">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">Lazy Daisy</h3>
                    <p class="text-gray-600 mb-4">
                        Also known as the detached chain stitch, it's perfect for creating flower petals, leaves, 
                        and other decorative elements.
                    </p>
                </div>
            </div>

            <!-- Feather Stitch -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                    <img src="/images/stitches/feather-stitch.svg" 
                         alt="Feather Stitch Example"
                         class="w-full h-64 object-contain bg-white">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">Feather Stitch</h3>
                    <p class="text-gray-600 mb-4">
                        A decorative stitch that creates a delicate, branching pattern. Ideal for borders, 
                        creating texture, and adding elegant details.
                    </p>
                </div>
            </div>

            <!-- Running Stitch -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                    <img src="/images/stitches/running-stitch.svg" 
                         alt="Running Stitch Example"
                         class="w-full h-64 object-contain bg-white">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">Running Stitch</h3>
                    <p class="text-gray-600 mb-4">
                        The most basic and versatile stitch in embroidery. Used for basting, outlining, and 
                        creating dashed lines and patterns.
                    </p>
                </div>
            </div>

            <!-- Split Stitch -->
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
                <div class="aspect-w-16 aspect-h-9">
                    <img src="/images/stitches/split-stitch.svg" 
                         alt="Split Stitch Example"
                         class="w-full h-64 object-contain bg-white">
                </div>
                <div class="p-6">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">Split Stitch</h3>
                    <p class="text-gray-600 mb-4">
                        Creates a fine, rope-like line by splitting through the previous stitch. Excellent for 
                        detailed outlines and filling small areas.
                    </p>
                </div>
            </div>
        </div>

        <!-- Learn More Section -->
        <div class="text-center mt-12">
            <a href="/courses" class="inline-flex items-center text-olive-600 hover:text-olive-700">
