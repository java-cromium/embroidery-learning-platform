<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="text-center">
    <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
      Embroidery Courses
    </h1>
    <p class="mt-3 max-w-2xl mx-auto text-xl text-gray-500 sm:mt-4">
      Learn embroidery from beginner to advanced levels
    </p>
  </div>

  <div class="mt-12">
    <div class="grid gap-5 max-w-lg mx-auto lg:grid-cols-3 lg:max-w-none">
      <% @courses.each do |course| %>
        <div class="flex flex-col rounded-lg shadow-lg overflow-hidden">
          <div class="flex-shrink-0">
            <img class="h-48 w-full object-cover" src="<%= course.thumbnail_url || '/images/default-course.jpg' %>" alt="<%= course.title %>">
          </div>
          <div class="flex-1 bg-white p-6 flex flex-col justify-between">
            <div class="flex-1">
              <div class="flex items-center">
                <% if course.premium? %>
                  <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-pink-100 text-pink-800">
                    Premium
                  </span>
                <% end %>
                <% if course.difficulty_level %>
                  <span class="ml-2 inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
                    <%= course.difficulty_level.capitalize %>
                  </span>
                <% end %>
              </div>
              <a href="/courses/<%= course.id %>" class="block mt-2">
                <p class="text-xl font-semibold text-gray-900">
                  <%= course.title %>
                </p>
                <p class="mt-3 text-base text-gray-500">
                  <%= course.description %>
                </p>
              </a>
            </div>
            <div class="mt-6">
              <% if current_user %>
                <div class="flex items-center">
                  <div class="flex-1">
                    <div class="bg-gray-200 rounded-full h-2">
                      <div class="bg-pink-500 rounded-full h-2" style="width: <%= course.completion_percentage(current_user) %>%"></div>
                    </div>
                  </div>
                  <span class="ml-2 text-sm text-gray-500">
                    <%= course.completion_percentage(current_user) %>%
                  </span>
                </div>
              <% end %>
              <div class="mt-3">
                <a href="/courses/<%= course.id %>" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-pink-600 hover:bg-pink-700 w-full justify-center">
                  View Course
                </a>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <% if @courses.empty? %>
    <div class="text-center mt-12">
      <h3 class="text-lg font-medium text-gray-900">No courses available yet</h3>
      <p class="mt-2 text-sm text-gray-500">
        Check back soon for new courses!
      </p>
    </div>
  <% end %>
</div>
