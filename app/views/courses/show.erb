<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="lg:grid lg:grid-cols-12 lg:gap-x-5">
    <!-- Course Info -->
    <div class="lg:col-span-8">
      <div>
        <div class="md:flex md:items-center md:justify-between md:space-x-4 xl:border-b xl:pb-6">
          <div>
            <h1 class="text-2xl font-bold text-gray-900"><%= @course.title %></h1>
            <p class="mt-2 text-sm text-gray-500">
              <%= @course.description %>
            </p>
          </div>
          <div class="mt-4 flex space-x-3 md:mt-0">
            <% if @course.premium? %>
              <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-pink-100 text-pink-800">
                Premium
              </span>
            <% end %>
            <% if @course.difficulty_level %>
              <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
                <%= @course.difficulty_level.capitalize %>
              </span>
            <% end %>
          </div>
        </div>

        <% if current_user %>
          <div class="py-3 xl:pt-6 xl:pb-0">
            <h2 class="text-sm font-medium text-gray-500">Your Progress</h2>
            <div class="mt-2">
              <div class="flex items-center">
                <div class="flex-1">
                  <div class="bg-gray-200 rounded-full h-2">
                    <div class="bg-pink-500 rounded-full h-2" style="width: <%= @user_progress %>%"></div>
                  </div>
                </div>
                <span class="ml-2 text-sm text-gray-500">
                  <%= @user_progress %>%
                </span>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Lessons List -->
        <div class="py-3 xl:pt-6 xl:pb-0">
          <h2 class="text-sm font-medium text-gray-500">Course Content</h2>
          <ul role="list" class="mt-2 divide-y divide-gray-200">
            <% @lessons.each do |lesson| %>
              <li class="py-4">
                <div class="flex items-center space-x-4">
                  <div class="flex-1 min-w-0">
                    <% if lesson.accessible_by?(current_user) %>
                      <a href="/courses/<%= @course.id %>/lessons/<%= lesson.id %>" class="text-sm font-medium text-pink-600 hover:text-pink-500">
                        <%= lesson.title %>
                      </a>
                    <% else %>
                      <span class="text-sm font-medium text-gray-900">
                        <%= lesson.title %>
                        <span class="ml-2 text-pink-600">
                          <i class="fas fa-lock"></i> Premium
                        </span>
                      </span>
                    <% end %>
                    <p class="text-sm text-gray-500">
                      <%= lesson.description %>
                    </p>
                  </div>
                  <div>
                    <% if current_user && lesson.completed_by?(current_user) %>
                      <span class="inline-flex items-center p-1 bg-green-100 text-green-700 rounded-full">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                      </span>
                    <% elsif lesson.duration_seconds %>
                      <span class="text-sm text-gray-500">
                        <%= Time.at(lesson.duration_seconds).utc.strftime("%M:%S") %>
                      </span>
                    <% end %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="lg:col-span-4">
      <div class="sticky top-4 space-y-4">
        <% unless current_user %>
          <div class="bg-white shadow sm:rounded-lg">
            <div class="px-4 py-5 sm:p-6">
              <h3 class="text-lg leading-6 font-medium text-gray-900">
                Sign in to track your progress
              </h3>
              <div class="mt-2 max-w-xl text-sm text-gray-500">
                <p>Create an account or sign in to save your progress and access premium content.</p>
              </div>
              <div class="mt-5">
                <a href="/login" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-white bg-pink-600 hover:bg-pink-700">
                  Sign in
                </a>
              </div>
            </div>
          </div>
        <% end %>

        <% if @course.premium? && current_user && !current_user.premium? %>
          <div class="bg-white shadow sm:rounded-lg">
            <div class="px-4 py-5 sm:p-6">
              <h3 class="text-lg leading-6 font-medium text-gray-900">
                Upgrade to Premium
              </h3>
              <div class="mt-2 max-w-xl text-sm text-gray-500">
                <p>Get access to all premium courses and lessons with a premium subscription.</p>
              </div>
              <div class="mt-5">
                <a href="/pricing" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-white bg-pink-600 hover:bg-pink-700">
                  View pricing
                </a>
              </div>
            </div>
          </div>
        <% end %>

        <div class="bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-gray-900">
              Course Details
            </h3>
            <dl class="mt-4 space-y-4">
              <div>
                <dt class="text-sm font-medium text-gray-500">Lessons</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= @lessons.count %> lessons</dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Total Duration</dt>
                <dd class="mt-1 text-sm text-gray-900">
                  <%= Time.at(@lessons.sum(:duration_seconds)).utc.strftime("%H:%M:%S") %>
                </dd>
              </div>
              <% if @course.category %>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Category</dt>
                  <dd class="mt-1 text-sm text-gray-900"><%= @course.category %></dd>
                </div>
              <% end %>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
