<div class="relative" data-controller="search">
  <div class="max-w-xl mx-auto">
    <label for="search" class="sr-only">Search</label>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
      <input
        type="search"
        name="q"
        id="search"
        class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-md leading-5 bg-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:ring-1 focus:ring-pink-500 focus:border-pink-500 sm:text-sm"
        placeholder="Search for courses, techniques, or patterns..."
        data-action="input->search#debounce"
        data-search-target="input"
        autocomplete="off"
      >
    </div>
    
    <!-- Search Results Dropdown -->
    <div class="absolute z-10 w-full mt-1 bg-white shadow-lg rounded-md overflow-hidden hidden" data-search-target="results">
      <div class="divide-y divide-gray-200" data-search-target="resultsList">
        <!-- Results will be dynamically inserted here -->
      </div>
      
      <!-- Loading State -->
      <div class="hidden p-4" data-search-target="loading">
        <div class="flex items-center justify-center">
          <svg class="animate-spin h-5 w-5 text-pink-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="ml-2 text-sm text-gray-500">Searching...</span>
        </div>
      </div>
      
      <!-- No Results State -->
      <div class="hidden p-4 text-center text-sm text-gray-500" data-search-target="noResults">
        No results found
      </div>
    </div>
  </div>
</div>
