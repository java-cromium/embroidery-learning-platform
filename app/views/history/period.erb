<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <!-- Breadcrumbs -->
  <nav class="flex py-4" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-4">
      <li>
        <div>
          <a href="/history" class="text-gray-400 hover:text-gray-500">
            <svg class="flex-shrink-0 h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
          </a>
        </div>
      </li>
      <li>
        <div class="flex items-center">
          <svg class="flex-shrink-0 h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
          </svg>
          <span class="ml-4 text-sm font-medium text-gray-500">
            <%= @period.era&.capitalize %>
          </span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- Period Header -->
  <div class="relative py-16">
    <% if @period.image_url %>
      <div class="absolute inset-x-0 top-0 h-1/2 bg-gray-50"></div>
      <div class="relative shadow-xl rounded-2xl overflow-hidden">
        <div class="absolute inset-0">
          <img class="h-full w-full object-cover" src="<%= @period.image_url %>" alt="<%= @period.name %>">
          <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black opacity-50"></div>
        </div>
        <div class="relative px-6 py-16 sm:px-12 sm:py-24">
          <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
            <%= @period.name %>
          </h1>
          <p class="mt-6 max-w-3xl text-xl text-gray-100">
            <%= @period.description %>
          </p>
          <div class="mt-8 flex space-x-4">
            <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-pink-100 text-pink-800">
              <%= @period.era&.capitalize %>
            </span>
            <% if @period.year_range %>
              <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
                <%= @period.year_range %>
              </span>
            <% end %>
            <% if @period.region %>
              <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                <%= @period.region %>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl sm:tracking-tight lg:text-6xl">
          <%= @period.name %>
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          <%= @period.description %>
        </p>
        <div class="mt-8 flex justify-center space-x-4">
          <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-pink-100 text-pink-800">
            <%= @period.era&.capitalize %>
          </span>
          <% if @period.year_range %>
            <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-gray-100 text-gray-800">
              <%= @period.year_range %>
            </span>
          <% end %>
          <% if @period.region %>
            <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
              <%= @period.region %>
            </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Artifacts Grid -->
  <div class="mt-16">
    <h2 class="text-3xl font-extrabold text-gray-900">
      Notable Artifacts
    </h2>
    <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <% @artifacts.each do |artifact| %>
        <div class="bg-white overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
          <% if artifact.image_url %>
            <div class="aspect-w-3 aspect-h-2">
              <img src="<%= artifact.image_url %>" alt="<%= artifact.name %>" class="object-cover">
            </div>
          <% end %>
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-gray-900">
              <%= artifact.name %>
            </h3>
            <% if artifact.location %>
              <p class="mt-1 text-sm text-gray-500">
                Found in <%= artifact.location %>
              </p>
            <% end %>
            <p class="mt-2 text-sm text-gray-600">
              <%= artifact.description %>
            </p>
            <div class="mt-4">
              <a href="/history/artifacts/<%= artifact.id %>" class="inline-flex items-center text-sm font-medium text-pink-600 hover:text-pink-500">
                View details
                <svg class="ml-1 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Related Techniques -->
  <% if @related_techniques.any? %>
    <div class="mt-16">
      <h2 class="text-3xl font-extrabold text-gray-900">
        Related Techniques
      </h2>
      <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <% @related_techniques.each do |technique| %>
          <div class="bg-white overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-200">
            <% if technique.image_url %>
              <div class="aspect-w-3 aspect-h-2">
                <img src="<%= technique.image_url %>" alt="<%= technique.name %>" class="object-cover">
              </div>
            <% end %>
            <div class="px-4 py-5 sm:p-6">
              <h3 class="text-lg font-medium text-gray-900">
                <%= technique.name %>
              </h3>
              <p class="mt-2 text-sm text-gray-600">
                <%= technique.description %>
              </p>
              <div class="mt-4">
                <% if technique.difficulty_level %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= technique.difficulty_level == 'beginner' ? 'green' : (technique.difficulty_level == 'intermediate' ? 'yellow' : 'red') %>-100 text-<%= technique.difficulty_level == 'beginner' ? 'green' : (technique.difficulty_level == 'intermediate' ? 'yellow' : 'red') %>-800">
                    <%= technique.difficulty_level.capitalize %>
                  </span>
                <% end %>
              </div>
              <div class="mt-4">
                <a href="/history/techniques/<%= technique.id %>" class="inline-flex items-center text-sm font-medium text-pink-600 hover:text-pink-500">
                  Learn more
                  <svg class="ml-1 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
