<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <!-- Breadcrumbs -->
  <nav class="flex py-4" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-4">
      <li>
        <div>
          <a href="/history" class="text-gray-400 hover:text-gray-500">
            <svg class="flex-shrink-0 h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
          </a>
        </div>
      </li>
      <li>
        <div class="flex items-center">
          <svg class="flex-shrink-0 h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
          </svg>
          <a href="#techniques" class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700">
            Techniques
          </a>
        </div>
      </li>
      <li>
        <div class="flex items-center">
          <svg class="flex-shrink-0 h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
          </svg>
          <span class="ml-4 text-sm font-medium text-gray-500">
            <%= @technique.name %>
          </span>
        </div>
      </li>
    </ol>
  </nav>

  <div class="mt-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-x-8 lg:items-start">
      <!-- Image and video section -->
      <div class="flex flex-col-reverse">
        <!-- Image -->
        <div class="aspect-w-1 aspect-h-1 rounded-lg bg-gray-100 overflow-hidden">
          <img src="<%= @technique.image_url %>" alt="<%= @technique.name %>" class="object-center object-cover">
        </div>
      </div>

      <!-- Technique info -->
      <div class="mt-10 px-4 sm:px-0 sm:mt-16 lg:mt-0">
        <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">
          <%= @technique.name %>
        </h1>

        <div class="mt-3 flex items-center">
          <% if @technique.difficulty_level %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= @technique.difficulty_level == 'beginner' ? 'green' : (@technique.difficulty_level == 'intermediate' ? 'yellow' : 'red') %>-100 text-<%= @technique.difficulty_level == 'beginner' ? 'green' : (@technique.difficulty_level == 'intermediate' ? 'yellow' : 'red') %>-800">
              <%= @technique.difficulty_level.capitalize %>
            </span>
          <% end %>
          <% if @technique.origin %>
            <span class="ml-4 text-sm text-gray-500">
              Origin: <%= @technique.origin %>
            </span>
          <% end %>
        </div>

        <div class="mt-6">
          <h3 class="sr-only">Description</h3>
          <div class="text-base text-gray-700 space-y-6">
            <p><%= @technique.description %></p>
          </div>
        </div>

        <% if @technique.historical_significance %>
          <div class="mt-8 border-t border-gray-200 pt-8">
            <h2 class="text-lg font-medium text-gray-900">Historical Significance</h2>
            <div class="mt-4 prose prose-sm text-gray-500">
              <p><%= @technique.historical_significance %></p>
            </div>
          </div>
        <% end %>

        <div class="mt-8 border-t border-gray-200 pt-8">
          <h2 class="text-lg font-medium text-gray-900">Technique Details</h2>

          <div class="mt-4">
            <% if @technique.required_materials.any? %>
              <div class="mb-6">
                <h3 class="text-sm font-medium text-gray-900">Required Materials</h3>
                <div class="mt-2">
                  <ul class="list-disc pl-4 text-sm text-gray-500">
                    <% @technique.required_materials.each do |material| %>
                      <li class="mb-1"><%= material %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            <% end %>

            <% if @technique.stitch_types.any? %>
              <div class="mb-6">
                <h3 class="text-sm font-medium text-gray-900">Stitch Types</h3>
                <div class="mt-2">
                  <ul class="list-disc pl-4 text-sm text-gray-500">
                    <% @technique.stitch_types.each do |stitch| %>
                      <li class="mb-1"><%= stitch %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            <% end %>

            <% if @technique.common_uses.any? %>
              <div class="mb-6">
                <h3 class="text-sm font-medium text-gray-900">Common Uses</h3>
                <div class="mt-2">
                  <ul class="list-disc pl-4 text-sm text-gray-500">
                    <% @technique.common_uses.each do |use| %>
                      <li class="mb-1"><%= use %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            <% end %>

            <% if @technique.variations.any? %>
              <div>
                <h3 class="text-sm font-medium text-gray-900">Variations</h3>
                <div class="mt-2">
                  <ul class="list-disc pl-4 text-sm text-gray-500">
                    <% @technique.variations.each do |variation| %>
                      <li class="mb-1"><%= variation %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <% if @technique.instructions %>
          <div class="mt-8 border-t border-gray-200 pt-8">
            <h2 class="text-lg font-medium text-gray-900">Basic Instructions</h2>
            <div class="mt-4 prose prose-sm text-gray-500">
              <%= @technique.instructions %>
            </div>
          </div>
        <% end %>

        <!-- Related Courses -->
        <div class="mt-8 border-t border-gray-200 pt-8">
          <h2 class="text-lg font-medium text-gray-900">Learn This Technique</h2>
          <div class="mt-4">
            <a href="/courses" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-pink-600 hover:bg-pink-700">
              Browse Related Courses
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
