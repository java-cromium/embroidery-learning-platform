<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="text-center">
    <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
      Embroidery Social Gallery
    </h1>
    <p class="mt-3 max-w-2xl mx-auto text-xl text-gray-500 sm:mt-4">
      Discover beautiful embroidery works from our community across different social platforms
    </p>
  </div>

  <div class="mt-12 grid gap-5 max-w-lg mx-auto lg:grid-cols-3 lg:max-w-none">
    <% @posts.each do |post| %>
      <div class="flex flex-col rounded-lg shadow-lg overflow-hidden">
        <div class="flex-shrink-0">
          <% if post.media_url %>
            <% if post.content_type == 'video' %>
              <video class="h-48 w-full object-cover" controls>
                <source src="<%= post.media_url %>" type="video/mp4">
                Your browser does not support the video tag.
              </video>
            <% else %>
              <img class="h-48 w-full object-cover" src="<%= post.media_url %>" alt="<%= post.caption&.truncate(50) %>">
            <% end %>
          <% end %>
        </div>
        <div class="flex-1 bg-white p-6 flex flex-col justify-between">
          <div class="flex-1">
            <p class="text-sm font-medium text-pink-600">
              <span class="capitalize"><%= post.platform %></span>
              <% if post.user %>
                by @<%= post.user.username %>
              <% end %>
            </p>
            <div class="block mt-2">
              <p class="text-xl font-semibold text-gray-900">
                <%= post.caption&.truncate(100) %>
              </p>
            </div>
          </div>
          <div class="mt-6 flex items-center">
            <div class="flex-shrink-0">
              <% case post.platform %>
              <% when 'instagram' %>
                <i class="fab fa-instagram text-2xl text-gray-400"></i>
              <% when 'facebook' %>
                <i class="fab fa-facebook text-2xl text-gray-400"></i>
              <% when 'twitter' %>
                <i class="fab fa-twitter text-2xl text-gray-400"></i>
              <% when 'tiktok' %>
                <i class="fab fa-tiktok text-2xl text-gray-400"></i>
              <% end %>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-gray-900">
                Posted
                <time datetime="<%= post.posted_at.iso8601 %>">
                  <%= time_ago_in_words(post.posted_at) %> ago
                </time>
              </p>
              <a href="<%= post.permalink %>" target="_blank" rel="noopener noreferrer" class="text-sm text-pink-600 hover:text-pink-500">
                View original post
              </a>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if @posts.empty? %>
  <div class="text-center mt-12">
    <h3 class="text-lg font-medium text-gray-900">No social media posts yet</h3>
    <p class="mt-2 text-sm text-gray-500">
      Connect your social media accounts to start sharing your embroidery work!
    </p>
    <div class="mt-6">
      <a href="/profile" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-pink-600 hover:bg-pink-700">
        Connect Social Media
      </a>
    </div>
  </div>
<% end %>
