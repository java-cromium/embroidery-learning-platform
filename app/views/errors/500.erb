<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Server Error - Embroidery Learning Platform</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <div class="min-h-screen flex items-center justify-center">
        <div class="max-w-md w-full px-6 py-12 bg-white shadow-lg rounded-lg">
            <div class="text-center">
                <h1 class="text-9xl font-bold text-pink-500">500</h1>
                <h2 class="mt-4 text-3xl font-semibold text-gray-800">Server Error</h2>
                <p class="mt-4 text-gray-600">Oops! Something went wrong on our end.</p>
                <p class="mt-2 text-sm text-gray-500">We're working to fix it. Please try again later.</p>
                <a href="/" class="mt-8 inline-block px-6 py-3 bg-pink-500 text-white font-semibold rounded-lg hover:bg-pink-600 transition duration-300">
                    Return Home
                </a>
            </div>
        </div>
    </div>
</body>
</html>
