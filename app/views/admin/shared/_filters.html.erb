<div class="bg-white shadow sm:rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <%= form_tag url_for, method: :get, data: { controller: 'filters', filter_presets_target: 'form' } do %>
      <div class="sm:flex-auto">
        <h3 class="text-lg font-medium text-gray-900">Filters</h3>
        <p class="mt-2 text-sm text-gray-500">
          Filter <%= resource_name.pluralize.titleize %> by specific criteria.
        </p>
      </div>
      <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <%= link_to "Clear Filters", clear_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
      </div>
    </div>

    <%= form_tag(filter_path, method: :get, class: "mt-6 space-y-8 md:space-y-0 md:grid md:grid-cols-3 md:gap-6", data: { "filters-target": "form" }) do %>
      <% filters.each do |filter| %>
        <div class="space-y-2">
          <% case filter[:type] %>
          <% when :multi_select %>
            <label for="<%= filter[:name] %>" class="block text-sm font-medium text-gray-700">
              <%= filter[:label] %>
            </label>
            <div class="mt-1">
              <select
                id="<%= filter[:name] %>"
                name="<%= filter[:name] %>[]" 
                multiple
                class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-pink-500 focus:border-pink-500 sm:text-sm rounded-md"
                data-action="change->filters#submit"
              >
                <% filter[:options].each do |option| %>
                  <option 
                    value="<%= option[:value] %>" 
                    <%= 'selected' if Array(params[filter[:name]]).include?(option[:value].to_s) %>
                  >
                    <%= option[:label] %>
                  </option>
                <% end %>
              </select>
            </div>

          <% when :range %>
            <label class="block text-sm font-medium text-gray-700">
              <%= filter[:label] %>
            </label>
            <div class="mt-1 grid grid-cols-2 gap-2">
              <div>
                <input
                  type="number"
                  name="<%= filter[:name] %>_min"
                  value="<%= params["#{filter[:name]}_min"] %>"
                  class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-pink-500 focus:border-pink-500 sm:text-sm"
                  placeholder="Min"
                  step="<%= filter[:step] || 1 %>"
                  min="<%= filter[:min] if filter[:min].present? %>"
                  max="<%= filter[:max] if filter[:max].present? %>"
                  data-action="change->filters#submit"
                >
              </div>
              <div>
                <input
                  type="number"
                  name="<%= filter[:name] %>_max"
                  value="<%= params["#{filter[:name]}_max"] %>"
                  class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-pink-500 focus:border-pink-500 sm:text-sm"
                  placeholder="Max"
                  step="<%= filter[:step] || 1 %>"
                  min="<%= filter[:min] if filter[:min].present? %>"
                  max="<%= filter[:max] if filter[:max].present? %>"
                  data-action="change->filters#submit"
                >
              </div>
            </div>

          <% when :rating %>
            <label class="block text-sm font-medium text-gray-700">
              <%= filter[:label] %>
            </label>
            <div class="mt-1 flex items-center space-x-1">
              <% (1..5).each do |rating| %>
                <button
                  type="button"
                  class="p-1 rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500"
                  data-action="click->filters#toggleRating"
                  data-rating="<%= rating %>"
                  data-filter-name="<%= filter[:name] %>"
                >
                  <svg class="h-6 w-6 <%= params[filter[:name]].to_i >= rating ? 'text-yellow-400' : 'text-gray-300' %>" 
                       xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                </button>
              <% end %>
              <input type="hidden" name="<%= filter[:name] %>" value="<%= params[filter[:name]] %>">
            </div>

          <% when :tags %>
            <label class="block text-sm font-medium text-gray-700">
              <%= filter[:label] %>
            </label>
            <div class="mt-1">
              <div class="flex flex-wrap gap-2" data-filters-target="tagContainer">
                <% filter[:options].each do |tag| %>
                  <button
                    type="button"
                    class="inline-flex items-center px-2.5 py-1.5 rounded-full text-xs font-medium
                           <%= Array(params[filter[:name]]).include?(tag[:value].to_s) ? 
                               'bg-pink-100 text-pink-800' : 
                               'bg-gray-100 text-gray-800 hover:bg-gray-200' %>"
                    data-action="click->filters#toggleTag"
                    data-tag-value="<%= tag[:value] %>"
                    data-filter-name="<%= filter[:name] %>"
                  >
                    <%= tag[:label] %>
                  </button>
                <% end %>
                <input type="hidden" name="<%= filter[:name] %>[]" value="<%= Array(params[filter[:name]]).join(',') %>">
              </div>
            </div>

          <% when :select %>
            <label for="<%= filter[:name] %>" class="block text-sm font-medium text-gray-700">
              <%= filter[:label] %>
            </label>
            <select
              id="<%= filter[:name] %>"
              name="<%= filter[:name] %>"
              class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-pink-500 focus:border-pink-500 sm:text-sm rounded-md"
              data-action="change->filters#submit"
            >
              <option value="">All <%= filter[:label].pluralize %></option>
              <% filter[:options].each do |option| %>
                <option value="<%= option[:value] %>" <%= 'selected' if params[filter[:name]] == option[:value].to_s %>>
                  <%= option[:label] %>
                </option>
              <% end %>
            </select>

          <% when :date_range %>
            <label class="block text-sm font-medium text-gray-700">
              <%= filter[:label] %>
            </label>
            <div class="mt-1 flex space-x-2">
              <div class="flex-1">
                <input
                  type="date"
                  name="<%= filter[:name] %>_from"
                  value="<%= params["#{filter[:name]}_from"] %>"
                  class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-pink-500 focus:border-pink-500 sm:text-sm"
                  data-action="change->filters#submit"
                >
              </div>
              <div class="flex-1">
                <input
                  type="date"
                  name="<%= filter[:name] %>_to"
                  value="<%= params["#{filter[:name]}_to"] %>"
                  class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-pink-500 focus:border-pink-500 sm:text-sm"
                  data-action="change->filters#submit"
                >
              </div>
            </div>

          <% when :search %>
            <label for="<%= filter[:name] %>" class="block text-sm font-medium text-gray-700">
              <%= filter[:label] %>
            </label>
            <div class="mt-1 relative rounded-md shadow-sm">
              <input
                type="text"
                name="<%= filter[:name] %>"
                id="<%= filter[:name] %>"
                value="<%= params[filter[:name]] %>"
                class="block w-full pr-10 border-gray-300 rounded-md focus:ring-pink-500 focus:border-pink-500 sm:text-sm"
                placeholder="<%= filter[:placeholder] %>"
                data-action="input->filters#debounceSubmit"
              >
              <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>

          <% when :boolean %>
            <div class="relative flex items-start">
              <div class="flex items-center h-5">
                <input
                  type="checkbox"
                  id="<%= filter[:name] %>"
                  name="<%= filter[:name] %>"
                  value="1"
                  <%= 'checked' if params[filter[:name]] == '1' %>
                  class="focus:ring-pink-500 h-4 w-4 text-pink-600 border-gray-300 rounded"
                  data-action="change->filters#submit"
                >
              </div>
              <div class="ml-3 text-sm">
                <label for="<%= filter[:name] %>" class="font-medium text-gray-700">
                  <%= filter[:label] %>
                </label>
                <% if filter[:description] %>
                  <p class="text-gray-500"><%= filter[:description] %></p>
                <% end %>
              </div>
            </div>

          <% end %>
        </div>
      <% end %>

      <% if show_apply_button %>
        <div class="mt-5 sm:mt-4 sm:flex sm:flex-row-reverse">
          <button
            type="submit"
            class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-pink-600 text-base font-medium text-white hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500 sm:ml-3 sm:w-auto sm:text-sm"
          >
            Apply Filters
          </button>
        </div>
      <% end %>
    <% end %>

    <% if active_filters.any? %>
      <div class="mt-4 flex flex-wrap gap-2">
        <% active_filters.each do |filter| %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-pink-100 text-pink-800">
            <%= filter[:label] %>: <%= filter[:value] %>
            <%= link_to "×", remove_filter_path(filter[:name]), class: "ml-1 text-pink-600 hover:text-pink-900" %>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
