%>

<% nav_items.each do |item| %>
  <% if item[:permission].blank? || render_if_allowed(*item[:permission]) %>
    <a href="<%= item[:path] %>" class="<%= request.path_info.start_with?(item[:path]) ? 'bg-gray-900 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white' %> group flex items-center px-2 py-2 text-sm font-medium rounded-md">
      <div class="space-y-1" data-controller="dropdown">
        <svg class="text-gray-400 group-hover:text-gray-300 mr-3 flex-shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <%= item[:icon] %>
        </svg>
        <%= item[:name] %>
      </div>
    </a>
  <% end %>
<% end %>
