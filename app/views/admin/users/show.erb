<div class="space-y-6" data-controller="user-profile">
  <!-- Action Bar -->
  <div class="bg-white px-4 py-5 shadow sm:rounded-lg sm:px-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <%= link_to "/admin/users", class: "mr-4 text-gray-400 hover:text-gray-500" do %>
          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        <% end %>
        <h2 class="text-lg font-medium text-gray-900">User Profile</h2>
      </div>
      
      <div class="flex space-x-3">
        <%= render_if_allowed(:users, :edit) do %>
          <%= action_button "Edit Profile", "/admin/users/#{@user.id}/edit",
              resource: :users,
              action: :edit %>
        <% end %>

        <%= render_if_allowed(:users, :manage_roles) do %>
          <%= action_button "Manage Roles", "/admin/users/#{@user.id}/roles",
              resource: :users,
              action: :manage_roles %>
        <% end %>

        <%= render_if_allowed(:users, :impersonate) do %>
          <%= action_button "Impersonate", "/admin/users/#{@user.id}/impersonate",
              resource: :users,
              action: :impersonate,
              data: { confirm: "Are you sure you want to impersonate this user?" } %>
        <% end %>
      </div>
    </div>
  </div>
  <!-- User Profile -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <img class="h-16 w-16 rounded-full" src="<%= @user.avatar_url || '/images/default-avatar.png' %>" alt="">
          <div class="ml-4">
            <h3 class="text-lg leading-6 font-medium text-gray-900">
              <%= @user.email %>
            </h3>
            <p class="mt-1 max-w-2xl text-sm text-gray-500">
              Member since <%= @user.created_at.strftime("%B %d, %Y") %>
            </p>
            <div class="mt-2 flex items-center space-x-2">
              <% @user.admin_roles.each do |role| %>
                <%= role_badge(role.name) %>
              <% end %>
            </div>
          </div>
        </div>
        <%= render_if_allowed(:users, :manage_roles) do %>
          <div>
            <form action="/admin/users/<%= @user.id %>/toggle_admin" method="post">
              <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white <%= @user.admin? ? 'bg-red-600 hover:bg-red-700' : 'bg-green-600 hover:bg-green-700' %> focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500">
                <%= @user.admin? ? 'Remove Admin' : 'Make Admin' %>
              </button>
            </form>
          </div>
        <% end %>
      </div>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
      <dl class="grid grid-cols-1 gap-x-4 gap-y-8 sm:grid-cols-2">
        <div class="sm:col-span-1">
          <dt class="text-sm font-medium text-gray-500">Username</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.username %></dd>
        </div>

        <%= render_if_allowed(:users, :view_sensitive) do %>
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Phone Number</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @user.phone_number || 'Not provided' %></dd>
          </div>
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">IP Address</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @user.last_sign_in_ip || 'Unknown' %></dd>
          </div>
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Device Info</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @user.last_sign_in_user_agent || 'Unknown' %></dd>
          </div>
        <% end %>
        <div class="sm:col-span-1">
          <dt class="text-sm font-medium text-gray-500">Status</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @user.admin? ? 'bg-purple-100 text-purple-800' : 'bg-green-100 text-green-800' %>">
              <%= @user.admin? ? 'Admin' : 'User' %>
            </span>
          </dd>
        </div>
        <div class="sm:col-span-1">
          <dt class="text-sm font-medium text-gray-500">Last Login</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @user.last_login_at&.strftime("%B %d, %Y at %I:%M %p") || 'Never' %></dd>
        </div>
        <div class="sm:col-span-1">
          <dt class="text-sm font-medium text-gray-500">Social Media Connected</dt>
          <dd class="mt-1 text-sm text-gray-900">
            <div class="space-x-2">
              <% if @user.facebook_connected? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  Facebook
                </span>
              <% end %>
              <% if @user.twitter_connected? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  Twitter
                </span>
              <% end %>
              <% if @user.instagram_connected? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-pink-100 text-pink-800">
                  Instagram
                </span>
              <% end %>
            </div>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Subscription Information -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">
        Subscription Information
      </h3>
    </div>
    <div class="border-t border-gray-200">
      <% if subscription = @user.current_subscription %>
        <dl>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Current Plan</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= subscription.subscription_plan.name %>
            </dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Status</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= subscription.active? ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                <%= subscription.status.titleize %>
              </span>
            </dd>
          </div>
          <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Started On</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= subscription.created_at.strftime("%B %d, %Y") %>
            </dd>
          </div>
          <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Next Billing Date</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
              <%= subscription.current_period_end.strftime("%B %d, %Y") %>
            </dd>
          </div>
          <% if subscription.cancel_at_period_end? %>
            <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500">Cancellation</dt>
              <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
                Scheduled to cancel on <%= subscription.current_period_end.strftime("%B %d, %Y") %>
              </dd>
            </div>
          <% end %>
        </dl>
      <% else %>
        <div class="px-4 py-5 sm:px-6">
          <p class="text-sm text-gray-500">No active subscription</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Payment Methods -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">
        Payment Methods
      </h3>
    </div>
    <div class="border-t border-gray-200">
      <% if @user.payment_methods.any? %>
        <ul role="list" class="divide-y divide-gray-200">
          <% @user.payment_methods.each do |payment_method| %>
            <li class="px-4 py-4 sm:px-6">
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                  </svg>
                  <div class="ml-3">
                    <p class="text-sm font-medium text-gray-900">
                      <%= payment_method.card_display %>
                      <% if payment_method.default? %>
                        <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                          Default
                        </span>
                      <% end %>
                    </p>
                    <p class="text-sm text-gray-500">
                      Expires <%= payment_method.expiration_display %>
                    </p>
                  </div>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-4 py-5 sm:px-6">
          <p class="text-sm text-gray-500">No payment methods added</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
