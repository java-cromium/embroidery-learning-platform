<div class="space-y-6" data-controller="users">
  <!-- Filters -->
  <%= render partial: 'admin/shared/filters',
             locals: {
               resource_name: 'user',
               filters: @filters,
               filter_path: admin_users_path,
               clear_path: admin_users_path,
               show_apply_button: false
             } %>
  <!-- Stats Cards -->
  <%= render_if_allowed(:users, :view_sensitive) do %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <%= stats_card("Total Users", @total_users) %>
      <%= stats_card("Active Users", @active_users) %>
      <%= stats_card("Premium Users", @premium_users, suffix: "%") %>
    </div>
  <% end %>
  <!-- Users List -->
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h2 class="text-xl font-semibold text-gray-900">Users</h2>
      <p class="mt-2 text-sm text-gray-700">
        A list of all users in your platform including their subscription status and registration date.
      </p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none space-x-3">
      <%= render_if_allowed(:users, :export) do %>
        <%= action_button "Export Users", "/admin/users/export", 
            icon: "download",
            data: { action: "users#export" } %>
      <% end %>
      <%= render_if_allowed(:users, :create) do %>
        <%= action_button "Add User", "/admin/users/new", 
            icon: "plus",
            resource: :users,
            action: :create %>
      <% end %>
    </div>
  </div>

  <div class="mt-8 flex flex-col">
    <div class="-my-2 -mx-4 overflow-x-auto sm:-mx-6 lg:-mx-8">
      <div class="inline-block min-w-full py-2 align-middle md:px-6 lg:px-8">
        <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 md:rounded-lg">
          <table class="min-w-full divide-y divide-gray-300">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">User</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Subscription</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Joined</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Last Login</th>
                <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                  <span class="sr-only">Actions</span>
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
              <% @users.each do |user| %>
                <tr>
                  <td class="whitespace-nowrap py-4 pl-4 pr-3 sm:pl-6">
                    <div class="flex items-center">
                      <div class="h-10 w-10 flex-shrink-0">
                        <img class="h-10 w-10 rounded-full" src="<%= user.avatar_url || '/images/default-avatar.png' %>" alt="">
                      </div>
                      <div class="ml-4">
                        <div class="font-medium text-gray-900"><%= user.email %></div>
                        <div class="text-gray-500"><%= user.username %></div>
                      </div>
                    </div>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= user.admin? ? 'bg-purple-100 text-purple-800' : 'bg-green-100 text-green-800' %>">
                      <%= user.admin? ? 'Admin' : 'User' %>
                    </span>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <% if subscription = user.current_subscription %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                        <%= subscription.subscription_plan.name %>
                      </span>
                    <% else %>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                        Free
                      </span>
                    <% end %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <%= user.created_at.strftime("%B %d, %Y") %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <%= user.last_login_at&.strftime("%B %d, %Y") || 'Never' %>
                  </td>
                  <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                    <%= action_menu "Actions" do %>
                      <div class="py-1" role="none">
                        <%= link_to "View Profile", "/admin/users/#{user.id}", 
                            class: "text-gray-700 block px-4 py-2 text-sm",
                            role: "menuitem" %>
                        
                        <%= render_if_allowed(:users, :edit) do %>
                          <%= link_to "Edit User", "/admin/users/#{user.id}/edit", 
                              class: "text-gray-700 block px-4 py-2 text-sm",
                              role: "menuitem" %>
                        <% end %>

                        <%= render_if_allowed(:users, :manage_roles) do %>
                          <%= link_to "Manage Roles", "/admin/users/#{user.id}/roles", 
                              class: "text-gray-700 block px-4 py-2 text-sm",
                              role: "menuitem" %>
                        <% end %>

                        <%= render_if_allowed(:users, :impersonate) do %>
                          <%= link_to "Impersonate", "/admin/users/#{user.id}/impersonate", 
                              class: "text-gray-700 block px-4 py-2 text-sm",
                              role: "menuitem",
                              data: { confirm: "Are you sure you want to impersonate this user?" } %>
                        <% end %>

                        <%= render_if_allowed(:users, :delete) do %>
                          <%= link_to "Delete User", "/admin/users/#{user.id}", 
                              class: "text-red-700 block px-4 py-2 text-sm",
                              role: "menuitem",
                              data: { 
                                confirm: "Are you sure you want to delete this user? This action cannot be undone.",
                                method: :delete
                              } %>
                        <% end %>
                      </div>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Pagination -->
  <% if @users.total_pages > 1 %>
    <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6">
      <div class="flex-1 flex justify-between sm:hidden">
        <% if @users.previous_page %>
          <a href="?page=<%= @users.previous_page %>" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
            Previous
          </a>
        <% end %>
        <% if @users.next_page %>
          <a href="?page=<%= @users.next_page %>" class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
            Next
          </a>
        <% end %>
      </div>
      <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
        <div>
          <p class="text-sm text-gray-700">
            Showing
            <span class="font-medium"><%= @users.offset + 1 %></span>
            to
            <span class="font-medium"><%= @users.offset + @users.length %></span>
            of
            <span class="font-medium"><%= @users.total_entries %></span>
            users
          </p>
        </div>
        <div>
          <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
            <% if @users.previous_page %>
              <a href="?page=<%= @users.previous_page %>" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                <span class="sr-only">Previous</span>
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </a>
            <% end %>

            <% (1..@users.total_pages).each do |page| %>
              <% if page == @users.current_page %>
                <span class="relative inline-flex items-center px-4 py-2 border border-pink-500 bg-pink-50 text-sm font-medium text-pink-600">
                  <%= page %>
                </span>
              <% else %>
                <a href="?page=<%= page %>" class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
                  <%= page %>
                </a>
              <% end %>
            <% end %>

            <% if @users.next_page %>
              <a href="?page=<%= @users.next_page %>" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                <span class="sr-only">Next</span>
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
              </a>
            <% end %>
          </nav>
        </div>
      </div>
    </div>
  <% end %>
</div>
