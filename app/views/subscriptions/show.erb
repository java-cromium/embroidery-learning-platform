<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
  <!-- Current Plan -->
  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">
        Subscription Details
      </h3>
      
      <% if @subscription %>
        <div class="mt-5">
          <div class="rounded-md bg-gray-50 px-6 py-5 sm:flex sm:items-start sm:justify-between">
            <div class="sm:flex sm:items-start">
              <div class="mt-3 sm:mt-0 sm:ml-4">
                <div class="text-sm font-medium text-gray-900">
                  <%= @subscription.subscription_plan.name %> Plan
                </div>
                <div class="mt-1 text-sm text-gray-600 sm:flex sm:items-center">
                  <div>
                    <%= @subscription.subscription_plan.price.format %> / <%= @subscription.subscription_plan.billing_interval %>
                  </div>
                  <span class="hidden sm:mx-2 sm:inline" aria-hidden="true">
                    &middot;
                  </span>
                  <div class="mt-1 sm:mt-0">
                    Renews on <%= @subscription.current_period_end.strftime("%B %d, %Y") %>
                  </div>
                </div>
              </div>
            </div>
            <div class="mt-4 sm:mt-0 sm:ml-6 sm:flex-shrink-0">
              <% if @subscription.cancel_at_period_end? %>
                <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                  Cancels on <%= @subscription.current_period_end.strftime("%B %d, %Y") %>
                </span>
                <form action="/subscription/reactivate" method="post" class="mt-2">
                  <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-pink-600 hover:bg-pink-700">
                    Reactivate Subscription
                  </button>
                </form>
              <% else %>
                <form action="/subscription/cancel" method="post">
                  <button type="submit" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                    Cancel Subscription
                  </button>
                </form>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Change Plan -->
        <div class="mt-6">
          <div class="flex items-center">
            <h4 class="text-sm font-medium text-gray-900">Change Plan</h4>
          </div>
          <ul role="list" class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
            <% SubscriptionPlan.where.not(id: @subscription.subscription_plan_id).each do |plan| %>
              <li class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400">
                <div class="flex-1 min-w-0">
                  <div class="focus:outline-none">
                    <span class="absolute inset-0" aria-hidden="true"></span>
                    <p class="text-sm font-medium text-gray-900">
                      <%= plan.name %>
                    </p>
                    <p class="text-sm text-gray-500">
                      <%= plan.price.format %> / <%= plan.billing_interval %>
                    </p>
                  </div>
                </div>
                <form action="/subscription/change_plan/<%= plan.id %>" method="post">
                  <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-full shadow-sm text-white bg-pink-600 hover:bg-pink-700">
                    Switch
                  </button>
                </form>
              </li>
            <% end %>
          </ul>
        </div>
      <% else %>
        <div class="mt-5">
          <div class="rounded-md bg-gray-50 px-6 py-5 text-center">
            <p class="text-sm text-gray-500">
              You don't have an active subscription.
              <a href="/pricing" class="font-medium text-pink-600 hover:text-pink-500">
                View our plans
              </a>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Payment Methods -->
  <div class="mt-8">
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Payment Methods
        </h3>
        <div class="mt-5">
          <div class="space-y-5">
            <% @payment_methods.each do |payment_method| %>
              <div class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between">
                    <p class="text-sm font-medium text-gray-900">
                      <%= payment_method.card_display %>
                      <% if payment_method.default? %>
                        <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                          Default
                        </span>
                      <% end %>
                    </p>
                    <div class="flex items-center space-x-2">
                      <% unless payment_method.default? %>
                        <form action="/payment_methods/<%= payment_method.id %>/default" method="post" class="inline">
                          <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50">
                            Make Default
                          </button>
                        </form>
                      <% end %>
                      <form action="/payment_methods/<%= payment_method.id %>" method="post" class="inline">
                        <input type="hidden" name="_method" value="delete">
                        <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50">
                          Remove
                        </button>
                      </form>
                    </div>
                  </div>
                  <p class="mt-1 text-sm text-gray-500">
                    Expires <%= payment_method.expiration_display %>
                    <% if payment_method.expiring_soon? %>
                      <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                        Expiring Soon
                      </span>
                    <% end %>
                  </p>
                </div>
              </div>
            <% end %>

            <!-- Add Payment Method -->
            <div class="mt-6">
              <div id="card-element" class="mt-1"></div>
              <div id="card-errors" class="mt-2 text-sm text-red-600" role="alert"></div>
              <button type="button" id="add-payment-method" class="mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-pink-600 hover:bg-pink-700">
                Add Payment Method
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Billing History -->
  <div class="mt-8">
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Billing Portal
        </h3>
        <div class="mt-5">
          <a href="/billing-portal" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-pink-600 hover:bg-pink-700">
            View Billing History
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://js.stripe.com/v3/"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const stripe = Stripe('<%= ENV["STRIPE_PUBLISHABLE_KEY"] %>');
    const elements = stripe.elements();
    const card = elements.create('card');
    card.mount('#card-element');

    const addButton = document.getElementById('add-payment-method');
    const errorElement = document.getElementById('card-errors');

    addButton.addEventListener('click', async function() {
      const { paymentMethod, error } = await stripe.createPaymentMethod({
        type: 'card',
        card: card,
      });

      if (error) {
        errorElement.textContent = error.message;
      } else {
        // Create hidden form and submit
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/payment_methods';

        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'payment_method_id';
        input.value = paymentMethod.id;

        form.appendChild(input);
        document.body.appendChild(form);
        form.submit();
      }
    });
  });
</script>
