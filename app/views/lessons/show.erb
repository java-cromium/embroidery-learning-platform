<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div class="lg:grid lg:grid-cols-12 lg:gap-x-5">
    <!-- Video Player and Content -->
    <div class="lg:col-span-8">
      <!-- Video Player -->
      <div class="aspect-w-16 aspect-h-9 bg-gray-900 rounded-lg overflow-hidden">
        <video
          id="lesson-video"
          class="w-full h-full"
          src="<%= @lesson.video_url %>"
          controls
          poster="<%= @lesson.thumbnail_url %>"
          data-lesson-id="<%= @lesson.id %>"
          data-progress="<%= @progress&.progress_percentage || 0 %>"
        >
          Your browser does not support the video tag.
        </video>
      </div>

      <!-- Lesson Info -->
      <div class="mt-6">
        <div class="md:flex md:items-center md:justify-between">
          <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
              <%= @lesson.title %>
            </h2>
          </div>
          <% if @lesson.premium? %>
            <div class="mt-4 flex-shrink-0 flex md:mt-0 md:ml-4">
              <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-medium bg-pink-100 text-pink-800">
                Premium
              </span>
            </div>
          <% end %>
        </div>

        <div class="mt-4">
          <p class="text-gray-500">
            <%= @lesson.description %>
          </p>
        </div>

        <% if @lesson.materials.any? %>
          <div class="mt-8">
            <h3 class="text-lg font-medium text-gray-900">Materials Needed</h3>
            <div class="mt-4 prose prose-pink">
              <ul>
                <% @lesson.materials.each do |material, details| %>
                  <li>
                    <strong><%= material %>:</strong>
                    <%= details['description'] %>
                    <% if details['link'] %>
                      <a href="<%= details['link'] %>" target="_blank" rel="noopener noreferrer" class="text-pink-600 hover:text-pink-500">
                        (Purchase Link)
                      </a>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="lg:col-span-4">
      <div class="sticky top-4 space-y-4">
        <!-- Course Progress -->
        <div class="bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-gray-900">
              Course Progress
            </h3>
            <div class="mt-4">
              <div class="relative pt-1">
                <div class="flex mb-2 items-center justify-between">
                  <div>
                    <span class="text-xs font-semibold inline-block text-pink-600">
                      <%= @course.completion_percentage(current_user) %>% Complete
                    </span>
                  </div>
                </div>
                <div class="overflow-hidden h-2 mb-4 text-xs flex rounded bg-pink-200">
                  <div style="width:<%= @course.completion_percentage(current_user) %>%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-pink-500"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Course Navigation -->
        <div class="bg-white shadow sm:rounded-lg">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-gray-900">
              Lesson Navigation
            </h3>
            <nav class="mt-4">
              <ul class="divide-y divide-gray-200">
                <% @course.lessons.each do |lesson| %>
                  <li class="py-2">
                    <a 
                      href="/courses/<%= @course.id %>/lessons/<%= lesson.id %>"
                      class="group flex items-center justify-between"
                    >
                      <span class="flex items-center">
                        <% if current_user && lesson.completed_by?(current_user) %>
                          <span class="mr-2 text-green-500">
                            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                          </span>
                        <% end %>
                        <span class="<%= lesson.id == @lesson.id ? 'text-pink-600' : 'text-gray-700 group-hover:text-pink-600' %> text-sm">
                          <%= lesson.title %>
                        </span>
                      </span>
                      <% if lesson.premium? && !current_user&.premium? %>
                        <span class="text-pink-600">
                          <i class="fas fa-lock"></i>
                        </span>
                      <% end %>
                    </a>
                  </li>
                <% end %>
              </ul>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const video = document.getElementById('lesson-video');
  if (!video) return;

  const lessonId = video.dataset.lessonId;
  let lastUpdateTime = 0;
  let watchTime = 0;

  function updateProgress() {
    const progress = (video.currentTime / video.duration) * 100;
    fetch(`/lessons/${lessonId}/progress`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        progress_percentage: progress,
        watch_time: watchTime
      })
    });
  }

  video.addEventListener('timeupdate', function() {
    const now = Date.now();
    if (now - lastUpdateTime >= 5000) { // Update every 5 seconds
      watchTime += 5;
      updateProgress();
      lastUpdateTime = now;
    }
  });

  video.addEventListener('ended', function() {
    updateProgress();
  });

  // Restore progress if available
  const savedProgress = video.dataset.progress;
  if (savedProgress > 0) {
    video.currentTime = (savedProgress / 100) * video.duration;
  }
});
</script>
